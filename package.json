{
  "name": "nekoai",
  "private": true,
  "version": "0.3.8",
  "homepage": "https://nekoai.dev/",
  "bugs": {
    "url": "https://github.com/nucket/nekoai/issues",
    "email": "hi@nekoai.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nucket/nekoai.git"
  },
  "author": {
    "name": "Naudy Castellanos",
    "email": "hi@nekoai.dev",
    "url": "https://naudycastellanos.com/"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:portable:win": "pwsh -File scripts/build-portable-windows.ps1",
    "sprites:convert": "python scripts/convert-sprites.py pets/classic-neko/sprites/ico pets/classic-neko/sprites",
    "version:bump": "node scripts/bump-version.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write",
    "*.{js,mjs,cjs}": "prettier --write",
    "*.yml": "prettier --write"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}
