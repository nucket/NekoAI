{
  "id": "classic-neko",
  "name": "Classic Neko",
  "author": "NekoAI",
  "version": "1.0.0",
  "description": "The original Neko cat from the classic 1989 desktop pet — pixel-perfect recreation",
  "sprite": {
    "path": "sprites.png",
    "frameWidth": 32,
    "frameHeight": 32
  },
  "defaultAnimation": "idle",
  "animations": {
    "idle": {
      "frames": [0, 1],
      "fps": 2,
      "loop": true
    },
    "walk_right": {
      "frames": [2, 3, 4, 5],
      "fps": 8,
      "loop": true
    },
    "walk_left": {
      "frames": [6, 7, 8, 9],
      "fps": 8,
      "loop": true
    },
    "happy": {
      "frames": [10, 11, 12],
      "fps": 6,
      "loop": true
    },
    "thinking": {
      "frames": [13, 14],
      "fps": 3,
      "loop": true
    },
    "sleep": {
      "frames": [15, 16],
      "fps": 1,
      "loop": true
    },
    "scratch": {
      "frames": [12, 13, 14],
      "fps": 6,
      "loop": true
    },
    "yawn": {
      "frames": [15, 16, 17],
      "fps": 4,
      "loop": false,
      "next": "idle"
    }
  },
  "triggers": {
    "onIdle":        "scratch",
    "onMouseNear":   "happy",
    "onMouseFar":    "idle",
    "onDragStart":   "walk_right",
    "onDragEnd":     "idle",
    "onDoubleClick": "happy",
    "onRightClick":  "thinking",
    "onSystemIdle":  "sleep",
    "onNight":       "sleep"
  }
}
